# OpenDash local configuration sample.
# Copy to .env or provide these as Gradle properties / CI secrets.
# Never put real secrets in this file.

OPENDASH_DASH_DEFAULT_PASSWORD=replace_with_dash_password
OPENDASH_GOOGLE_WEB_CLIENT_ID=replace_with_google_web_client_id
OPENDASH_RELEASE_STORE_FILE=replace_with_absolute_or_ci_keystore_path
OPENDASH_RELEASE_STORE_PASSWORD=replace_with_release_store_password
OPENDASH_RELEASE_KEY_ALIAS=replace_with_release_key_alias
OPENDASH_RELEASE_KEY_PASSWORD=replace_with_release_key_password
